{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "app/admin/page.jsx",
    "app/ilts-test/page.jsx",
    "app/dashboard/page.jsx",
    "app/login/page.jsx",
    "app/practice/listening/[id]/page.jsx",
    "app/practice/writing/[id]/page.jsx",
    "app/practice/reading/[id]/page.jsx",
    "app/layout.jsx",
    "app/page.jsx",
    "components/Footer/Footer.jsx",
    "components/Navbar/Navbar.jsx",
    "components/Shared/AdminUi.jsx",
    "components/Shared/Badge.jsx",
    "components/Shared/CheckBoxIcon.jsx",
    "components/Shared/MinusIcon.jsx",
    "components/Shared/PlusIcon.jsx",
    "components/Shared/PrimaryBtn.jsx",
    "components/Shared/Resultmodal.jsx",
    "components/Shared/SectionLabel.jsx",
    "components/Shared/StarIcon.jsx",
    "components/Shared/Testsharedui.jsx",
    "features/Store.js",
    "features/slice/Attemptslice.js",
    "features/slice/auth/authSlice.js",
    "firebase/firebaseConfig.js",
    "hooks/Usetestsession.jsx",
    "lib/axios.js",
    "pages/admin/Fulltestcreator.jsx",
    "pages/admin/Listeningtestcreator.jsx",
    "pages/admin/Questionbuilder.jsx",
    "pages/admin/Readingtestcreator.jsx",
    "pages/admin/Writingtestcreator.jsx",
    "pages/Home/Choose.jsx",
    "pages/Home/Faq.jsx",
    "pages/Home/FinalCTA.jsx",
    "pages/Home/GuideLine.jsx",
    "pages/Home/Hero.jsx",
    "pages/Home/MockText.jsx",
    "pages/Home/Progress.jsx",
    "pages/Home/QPrectice.jsx",
    "pages/Home/QuestionPractice.jsx",
    "pages/Home/QuestionTypes.jsx",
    "pages/Home/ScrollingBanner.jsx",
    "pages/Home/SectionTest.jsx",
    "pages/Home/Stats.jsx",
    "pages/Home/StudyAbroad.jsx",
    "pages/Home/Testimonial.jsx",
    "Providers/AdminPrivateRoute.jsx",
    "Providers/PrivateRoute.jsx",
    "Providers/Provider.jsx"
, "action/student.js", "action/auth.js", "action/admin.js"  ],
  "exclude": [
    "node_modules"
  ]
}
